# wrapper.env
RELAY_SERVER_URL=ws://127.0.0.1:9500/ws/agent
CODEX_REAL_BINARY=codex
CODEX_REMOTE_WRAPPER_NAME_MODE=workspace_basename
CODEX_REMOTE_WRAPPER_INTEGRATION_MODE=editor_settings
# Enable relay flow debug logging (true/false)
CODEX_REMOTE_DEBUG_RELAY_FLOW=false
# Enable relay raw data debug logging (true/false)
CODEX_REMOTE_DEBUG_RELAY_RAW=false

# services.env
# Override relay WebSocket listen host
RELAY_HOST=
# Override admin API listen host
RELAY_API_HOST=
RELAY_PORT=9500
RELAY_API_PORT=9501
# Select which Feishu app entry to use (from config.json feishu.apps[].id)
FEISHU_GATEWAY_ID=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_USE_SYSTEM_PROXY=false
# Optional, opt-in WeCom (企业微信 aibot) second channel. Leave both empty to run
# Feishu-only (default, unchanged). Set both to additively enable WeCom.
WECOM_BOT_ID=
WECOM_SECRET=
